{
  "name": "gabagool-debug",
  "displayName": "Gabagool WASM Debugger",
  "version": "0.0.1",
  "publisher": "gabagool",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Debuggers"],
  "contributes": {
    "debuggers": [
      {
        "type": "gabagool",
        "label": "Gabagool WASM",
        "program": "./bin/gabagool-debug-adapter",
        "languages": ["wat", "wasm"],
        "configurationAttributes": {
          "launch": {
            "required": ["program"],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to .wasm file"
              },
              "function": {
                "type": "string",
                "description": "Function to debug (auto-detected if omitted)"
              },
              "args": {
                "type": "string",
                "description": "Arguments (comma-separated integers, e.g. '3,2')",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "gabagool",
            "request": "launch",
            "name": "Debug WASM",
            "program": "${workspaceFolder}/programs/fibonacci.wasm",
            "args": [10]
          }
        ]
      }
    ]
  }
}
